# Database (SQLite, local file). No secrets required for version one.
DATABASE_URL="file:./dev.db"

# --- Optional: only needed for extra features. Never required to run the bot. ---

# If set, DailyReport can be pushed to Telegram by a script Hermes runs on its cron.
# Leave blank to keep the bot fully local/no-network for reports.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Data source mode: "live" tries real Polymarket public APIs first and falls back
# to clearly-labeled demo data if a call fails. "demo" always uses demo data.
DATA_SOURCE_MODE=live

# Public Polymarket endpoints (no auth/keys required — these are public read APIs).
# Overridable in case Polymarket changes hosts.
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com

# Simulated paper-trading bankroll. Position sizing itself stays fixed
# $5-$20 per trade (see rules); this caps total simultaneous exposure so
# the simulation actually tests whether this budget would have survived.
STARTING_BALANCE=200
# NEVER put a private key or wallet seed phrase in this file or anywhere in this app.
# This app does not sign transactions and will not accept a private key.
